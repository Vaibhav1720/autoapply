{
  "indexingPolicy": {
    "indexingMode": "consistent",
    "automatic": true,
    "includedPaths": [{"path": "/*"}],
    "excludedPaths": [
      {"path": "/embedding/*"},
      {"path": "/\"_etag\"/?"}
    ],
    "vectorIndexes": [
      {"path": "/embedding", "type": "quantizedFlat"}
    ]
  },
  "vectorEmbeddingPolicy": {
    "vectorEmbeddings": [
      {
        "path": "/embedding",
        "dataType": "float32",
        "dimensions": 3072,
        "distanceFunction": "cosine"
      }
    ]
  }
}
