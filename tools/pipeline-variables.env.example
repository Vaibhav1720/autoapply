# Copy to pipeline-variables.env and fill in (pipeline-variables.env is gitignored).
# Then: bash tools/apply-pipeline-config.sh
# Or paste the same values in chat for your agent to apply.

# --- Azure DevOps (required for deploy stages) ---
azureSubscription=
functionAppName=autoapply-func-dev
resourceGroup=rg-autoapply-dev
apiBaseUrl=https://autoapply-func-dev.azurewebsites.net
googleClientId=
adminEmails=vibhuu1720@gmail.com
staticWebAppDeploymentToken=

# --- Static Web App hostname (no https://) for extension/configure-extension.sh ---
swaHost=mango-ocean-0f1de6810.2.azurestaticapps.net

# --- Toggles ---
enableDeploy=true
runInfraDeploy=false

# --- Optional: Azure DevOps project (for apply-pipeline-config.sh) ---
# AZURE_DEVOPS_ORG=https://dev.azure.com/YourOrg
# AZURE_DEVOPS_PROJECT=AutoApply
# AZURE_DEVOPS_PIPELINE_ID=
