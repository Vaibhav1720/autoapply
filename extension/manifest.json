  "content_scripts": [
    {
      "matches": [
        "https://autoapplynow.in/*",
        "https://mango-ocean-0f1de6810.2.azurestaticapps.net/*",
        "https://*.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://*.lever.co/*",
